# mount point   fstype    device                              flags
/system         ext4      /dev/block/mapper/system            flags=display="System";logical
/vendor         ext4      /dev/block/mapper/vendor            flags=display="Vendor";logical
/product        ext4      /dev/block/mapper/product           flags=display="Product";logical
/data           f2fs      /dev/block/by-name/userdata         flags=display="Data"
/metadata       ext4      /dev/block/by-name/md_udc           flags=display="Metadata"
/persist        ext4      /dev/block/by-name/persist          flags=display="Persist"
/lenovocust     ext4      /dev/block/by-name/lenovocust       flags=display="LenovoCust"
/protect_f      ext4      /dev/block/by-name/protect1         flags=display="Protect_f"
/protect_s      ext4      /dev/block/by-name/protect2         flags=display="Protect_s"
/nvdata         ext4      /dev/block/by-name/nvdata           flags=display="NVData"
/nvcfg          ext4      /dev/block/by-name/nvcfg            flags=display="NVCfg"
/boot           emmc      /dev/block/by-name/boot             flags=display="Boot"
/sdcard1        auto      /devices/platform/externdevice*     flags=display="MicroSD";storage;wipeingui;removable
/usb-otg        auto      /devices/platform/mt_usb*           flags=display="USB OTG";storage;wipeingui;removable
